          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[Check Status] GET /check-status — 200 та envelope.data (масив)', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});",
                  "pm.test('[Check Status] елемент data[0] — id, geos, groups (обʼєкт)', function () {",
                  "  const body = pm.response.json();",
                  "  if (!body.data || body.data.length === 0) {",
                  "    return;",
                  "  }",
                  "  const item = body.data[0];",
                  "  pm.expect(item).to.have.property('id');",
                  "  pm.expect(item).to.have.property('geos');",
                  "  pm.expect(item.geos).to.be.an('array');",
                  "  if (item.geos.length === 0) {",
                  "    return;",
                  "  }",
                  "  const geo = item.geos[0];",
                  "  pm.expect(geo).to.have.property('iso_3166');",
                  "  pm.expect(geo).to.have.property('groups');",
                  "  pm.expect(geo.groups).to.be.an('object');",
                  "  const groupKeys = Object.keys(geo.groups);",
                  "  if (groupKeys.length === 0) {",
                  "    return;",
                  "  }",
