    {
      "name": "Geos",
      "description": "Список GEO та один термін за id.",
      "item": [
        {
          "name": "Geo List",
          "description": "GET /geos — усі доступні GEO (slug, iso, casino_count, group_count тощо).",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[Geos] GET /geos — 200 та envelope.data (масив)', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});"
